@inject ProductApiService ProductService
@inject OrderApiService OrderService
@inject ISnackbar Snackbar

<MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
           StartIcon="@Icons.Material.Filled.Add" OnClick="Open">
    Add Order
</MudButton>

<MudDialog @bind-IsVisible="_open" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">Add Order</MudText></TitleContent>
    <DialogContent>
        <div style="display:flex; flex-direction:column; gap:16px; margin-top:8px;">

            <!-- Product autocomplete — disables out-of-stock items -->
            <MudAutocomplete T="Product" Label="Product *" @bind-Value="_selectedProduct"
                             SearchFunc="SearchProducts" ToStringFunc="@(p => p?.Name ?? "")"
                             Variant="Variant.Outlined" Placeholder="Select a product…"
                             ResetValueOnEmptyText="false">
                <ItemTemplate Context="p">
                    <div style="display:flex; justify-content:space-between; width:100%;
                                @(p.Stock == 0 ? "opacity:0.4; pointer-events:none;" : "")">
                        <span>@p.Name</span>
                        <span style="font-size:0.75rem; color:var(--muted-foreground);">
                            @p.Price.ToString("C") · @(p.Stock > 0 ? $"{p.Stock} in stock" : "out of stock")
                        </span>
                    </div>
                </ItemTemplate>
            </MudAutocomplete>

            <!-- Quantity -->
            <MudNumericField @bind-Value="_quantity" Label="Quantity *" Min="1"
                             Placeholder="1" Variant="Variant.Outlined" HideSpinButtons="true"
                             HelperText="@(_selectedProduct is not null ? $"{_selectedProduct.Stock} available" : "")" />

            <!-- Live total -->
            @if (_selectedProduct is not null && _quantity > 0)
            {
                <p style="margin:0; font-size:0.875rem; color:var(--muted-foreground);">
                    Total: <strong style="color:var(--foreground);">@((_selectedProduct.Price * _quantity).ToString("C"))</strong>
                </p>
            }

            <!-- Client-side stock guard -->
            @if (_selectedProduct is not null && _quantity > _selectedProduct.Stock)
            {
                <MudAlert Severity="Severity.Error" Dense="true">
                    Only @_selectedProduct.Stock available
                </MudAlert>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="@(() => _open = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(_submitting || _selectedProduct is null || _quantity < 1 || _quantity > (_selectedProduct?.Stock ?? 0))"
                   OnClick="Submit">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Placing…</span>
            }
            else
            {
                <span>Place Order</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public EventCallback OnCreated { get; set; }

    private bool _open = false;
    private bool _submitting = false;

    private List<Product> _allProducts = [];
    private Product? _selectedProduct;
    private int _quantity = 1;

    private async Task Open()
    {
        _open = true;
        _selectedProduct = null;
        _quantity = 1;

        if (!_allProducts.Any())
        {
            try
            {
                var result = await ProductService.GetProductsAsync(new ProductQuery(Limit: 9999));
                _allProducts = result.Data.ToList();
            }
            catch { }
        }
    }

    // MudAutocomplete search — filter by name (MudBlazor 6 delegate: Func<string, Task<IEnumerable<T>>>)
    private Task<IEnumerable<Product>> SearchProducts(string value)
    {
        var filtered = string.IsNullOrEmpty(value)
            ? _allProducts
            : _allProducts.Where(p => p.Name.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(filtered);
    }

    private async Task Submit()
    {
        if (_selectedProduct is null || _quantity < 1) return;
        _submitting = true;
        try
        {
            await OrderService.CreateOrderAsync(new CreateOrderRequest(_selectedProduct.Id, _quantity));
            Snackbar.Add("Order placed successfully", Severity.Success);
            _allProducts = []; // invalidate cache so next open fetches fresh stock
            _open = false;
            _submitting = false;
            StateHasChanged(); // force dialog to close before parent reloads
            await OnCreated.InvokeAsync();
        }
        catch (ApiException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _submitting = false;
        }
    }
}
