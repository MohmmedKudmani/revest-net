@inject OrderApiService OrderService
@inject ISnackbar Snackbar

<MudDialog @bind-IsVisible="_open" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">Delete Order?</MudText></TitleContent>
    <DialogContent>
        <p style="margin:0; color:var(--muted-foreground);">
            This will permanently delete the order for
            <strong style="color:var(--foreground);">"@ProductName"</strong>.
            This action cannot be undone.
        </p>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="@(() => _open = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@_submitting"
                   OnClick="Submit">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Deleting…</span>
            }
            else
            {
                <span>Delete</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Ghost icon trash trigger with destructive tint -->
<MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small"
               Variant="Variant.Text"
               Style="color:oklch(0.577 0.245 27.325 / 60%);"
               OnClick="@(() => _open = true)" />

@code {
    [Parameter, EditorRequired] public Order Order    { get; set; } = null!;
    [Parameter] public EventCallback OnDeleted { get; set; }

    private bool _open = false;
    private bool _submitting = false;

    private string ProductName => Order.Product?.Name ?? $"order {Order.Id[..8]}…";

    private async Task Submit()
    {
        _submitting = true;
        try
        {
            await OrderService.DeleteOrderAsync(Order.Id);
            Snackbar.Add("Order deleted", Severity.Success);
            _open = false;
            _submitting = false;
            StateHasChanged();
            await OnDeleted.InvokeAsync();
        }
        catch (ApiException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _submitting = false; }
    }
}
