@page "/orders"
@implements IDisposable
@using RevestAdmin.Helpers
@inject OrderApiService OrderService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<!-- Page header -->
<div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:24px;">
    <div>
        <h1 style="font-family:'Inter',sans-serif; font-size:1.875rem; font-weight:600; letter-spacing:-0.02em; margin:0;">
            Orders
        </h1>
        @if (_result is not null)
        {
            <div style="margin-top:6px;">
                <span class="revest-badge revest-badge-primary">@_result.Total orders</span>
            </div>
        }
    </div>
    <AddOrderDialog OnCreated="Reload" />
</div>

<!-- Filters -->
<OrderFilters Query="@_currentQuery" OnFilterChanged="ApplyFilters" />

<!-- Loading bar -->
@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="border-radius:4px; margin-bottom:8px;" />
}

@if (_result is not null)
{
    @if (_result.Data.Any())
    {
        <OrdersTable Orders="@_result.Data.ToList()" OnReload="Reload" />

        <DataPagination CurrentPage="@_currentQuery.Page" TotalPages="@_result.TotalPages"
                        Total="@_result.Total" Limit="@_currentQuery.Limit"
                        OnPageChange="GoToPage" />
    }
    else
    {
        <!-- Empty state -->
        <div class="revest-empty">
            <div class="revest-empty-icon">
                <MudIcon Icon="@Icons.Material.Outlined.Checklist" Style="font-size:22px;" />
            </div>
            @if (_hasFilters)
            {
                <div>
                    <p style="font-weight:600; margin:0;">No orders match your filters</p>
                    <p style="color:var(--muted-foreground); margin:4px 0 0;">Try adjusting your search or filters.</p>
                </div>
            }
            else
            {
                <div>
                    <p style="font-weight:600; margin:0;">No orders yet</p>
                    <p style="color:var(--muted-foreground); margin:4px 0 0;">Place your first order to get started.</p>
                </div>
                <AddOrderDialog OnCreated="Reload" />
            }
        </div>
    }
}

@code {
    private PaginatedResult<Order>? _result;
    private OrderQuery _currentQuery = new();
    private bool _loading = false;
    private bool _hasFilters => !string.IsNullOrEmpty(_currentQuery.Search)
        || !string.IsNullOrEmpty(_currentQuery.Status);

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await LoadFromUrl();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => await InvokeAsync(LoadFromUrl);

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    private async Task LoadFromUrl()
    {
        var uri = Nav.Uri;
        _currentQuery = new OrderQuery(
            Search: QueryHelper.GetParam(uri, "search"),
            Status: QueryHelper.GetParam(uri, "status"),
            SortBy: QueryHelper.GetParam(uri, "sortBy") ?? "createdAt",
            SortOrder: QueryHelper.GetParam(uri, "sortOrder") ?? "desc",
            Page: QueryHelper.GetIntParam(uri, "page", 1),
            Limit: QueryHelper.GetIntParam(uri, "limit", 10)
        );

        _loading = true;
        StateHasChanged();

        try
        {
            _result = await OrderService.GetOrdersAsync(_currentQuery);

            // Out-of-bounds page guard
            if (_result.TotalPages > 0 && _currentQuery.Page > _result.TotalPages)
                GoToPage(_result.TotalPages);
        }
        catch (ApiException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _loading = false; StateHasChanged(); }
    }

    private void ApplyFilters(OrderQuery q)
    {
        var p = new Dictionary<string, object?>
        {
            ["search"]    = string.IsNullOrEmpty(q.Search) ? null : (object?)q.Search,
            ["status"]    = string.IsNullOrEmpty(q.Status) ? null : (object?)q.Status,
            ["sortBy"]    = q.SortBy ?? "createdAt",
            ["sortOrder"] = q.SortOrder ?? "desc",
            ["page"]      = 1,
            ["limit"]     = q.Limit,
        };
        Nav.NavigateTo(Nav.GetUriWithQueryParameters(p));
    }

    private void GoToPage(int page)
        => Nav.NavigateTo(Nav.GetUriWithQueryParameters(
            new Dictionary<string, object?> { ["page"] = page }));

    private async Task Reload() => await LoadFromUrl();
}
