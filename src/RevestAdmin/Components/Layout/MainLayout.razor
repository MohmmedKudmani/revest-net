@inherits LayoutComponentBase
@inject NavigationManager Nav

<MudThemeProvider Theme="RevestTheme.Theme" />
<MudSnackbarProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />

<MudLayout>
    <!-- Sidebar: 256px, persistent, left, light bg -->
    <MudDrawer Open="true" Variant="@DrawerVariant.Persistent"
               Elevation="0" ClipMode="DrawerClipMode.Never"
               Style="border-right: 1px solid var(--sidebar-border);">
        <NavMenu />
    </MudDrawer>

    <!-- Mobile app bar (hidden on md+) — sidebar trigger only -->
    <MudAppBar Elevation="0" Fixed="true"
               Style="display:none; border-bottom:1px solid var(--border); background:var(--card);"
               Class="d-flex d-md-none">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" />
    </MudAppBar>

    <MudMainContent>
        <!-- Inner container: max 1400px centred, 32px padding -->
        <div style="padding:32px; max-width:1400px; margin:0 auto; width:100%;">
            @Body
        </div>
    </MudMainContent>
</MudLayout>
